# .gitignore for AI Employee Vault
# CRITICAL: This file prevents secrets from being committed to Git

# =============================================
# ENVIRONMENT FILES (CONTAIN SECRETS)
# =============================================
.env
.env.*
.env.local
.env.*.local
.env.cloud
.env.local

# =============================================
# TOKEN FILES
# =============================================
*.token
*.tokens
*.access_token
*.refresh_token
*.id_token
*.session_token

# =============================================
# KEY FILES
# =============================================
*.key
*.pem
*.crt
*.p12
*.pfx
*.der
*.asc

# =============================================
# CREDENTIAL DIRECTORIES
# =============================================
sessions/
credentials/
oauth/
auth/
.auth/
.secrets/

# =============================================
# SECRET FILES
# =============================================
*.secret
*.secrets
*.password
*.passwd
*.credential
*.credentials

# =============================================
# AUDIT LOGS (CONTAIN SENSITIVE DATA)
# =============================================
Audit_Logs/
Logs/audit*
Logs/*sensitive*

# =============================================
# CEO BRIEFINGS (BUSINESS SENSITIVE)
# =============================================
CEO_Briefings/

# =============================================
# IDE AND EDITOR FILES
# =============================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-*

# =============================================
# OS FILES
# =============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# =============================================
# SYNCTHING FILES
# =============================================
.syncthing
syncthing-config.xml

# =============================================
# PYTHON GENERATED
# =============================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# =============================================
# VIRTUAL ENVIRONMENTS
# =============================================
.venv/
venv/
ENV/
env/

# =============================================
# TESTING
# =============================================
.pytest_cache/
.coverage
htmlcov/
.tox/

# =============================================
# NOTES
# =============================================
# The following folders ARE synced (markdown/state only):
# - Needs_Action/
# - In_Progress/
# - Pending_Approval/
# - Approved/
# - Rejected/
# - Done/
# - Plans/
# - Updates/ (drafts only, no secrets)
# - Signals/
# - Dashboard.md
# - Company_Handbook.md
# - Business_Goals.md
