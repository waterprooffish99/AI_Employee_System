# =============================================================================
# AI EMPLOYEE SYSTEM - ENVIRONMENT CONFIGURATION TEMPLATE
# Platinum Tier - Hackathon 0
# =============================================================================
# 
# INSTRUCTIONS:
# 1. Copy this file to .env (DO NOT commit .env to git!)
#    cp .env.example .env
# 2. Replace ALL placeholder values with your actual credentials
# 3. For production: Use strong passwords, never use defaults
# 4. After changing .env: docker-compose down -v && docker-compose up -d
#
# SECURITY: This file contains SECRETS. Never commit to version control.
# =============================================================================

# =============================================================================
# DEVELOPMENT MODE
# =============================================================================
DRY_RUN=true
LOG_LEVEL=INFO

# =============================================================================
# ODOO ERP CONFIGURATION (Gold Tier)
# =============================================================================
# CRITICAL: ODOO_DB_PASSWORD must match POSTGRES_PASSWORD below
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_db
ODOO_USERNAME=admin
ODOO_DB_PASSWORD=odoo123  # CHANGE IN PRODUCTION - must match POSTGRES_PASSWORD
ODOO_ADMIN_PASSWORD=odoo123  # CHANGE IN PRODUCTION
ODOO_API_KEY=generate_after_first_login  # Generate in Odoo after first login

# =============================================================================
# POSTGRESQL DATABASE
# =============================================================================
# CRITICAL: Must match ODOO_DB_PASSWORD above
POSTGRES_PASSWORD=odoo123  # CHANGE IN PRODUCTION - must match ODOO_DB_PASSWORD
POSTGRES_DB=odoo_db
POSTGRES_USER=odoo

# =============================================================================
# WHATSAPP - TWILIO API (Silver/Gold Tier)
# =============================================================================
# Sign up: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # REPLACE
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here  # REPLACE
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_TO_NUMBER=whatsapp:+YOUR_NUMBER  # REPLACE

# =============================================================================
# TWITTER/X API (Gold Tier)
# =============================================================================
# Apply: https://developer.twitter.com/en/portal/dashboard (24-48 hr approval)
TWITTER_API_KEY=your_twitter_api_key  # REPLACE
TWITTER_API_SECRET=your_twitter_api_secret  # REPLACE
TWITTER_ACCESS_TOKEN=your_twitter_access_token  # REPLACE
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret  # REPLACE
TWITTER_BEARER_TOKEN=your_twitter_bearer_token  # REPLACE

# =============================================================================
# GMAIL/OAUTH (Silver Tier)
# =============================================================================
# Setup: https://developers.google.com/gmail/api/quickstart/python
GMAIL_CREDENTIALS=/path/to/gmail_credentials.json  # REPLACE
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com  # REPLACE
GMAIL_CLIENT_SECRET=your_client_secret  # REPLACE
GMAIL_REDIRECT_URI=http://localhost:8080/callback
GMAIL_REFRESH_TOKEN=your_refresh_token  # REPLACE after OAuth

# =============================================================================
# LINKEDIN (Silver Tier)
# =============================================================================
# Setup: https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_ID=your_linkedin_client_id  # REPLACE
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret  # REPLACE
LINKEDIN_REDIRECT_URI=http://localhost:8080/linkedin/callback
LINKEDIN_USERNAME=your_linkedin_username  # REPLACE
LINKEDIN_PASSWORD=your_linkedin_password  # REPLACE

# =============================================================================
# FACEBOOK/INSTAGRAM (Gold Tier)
# =============================================================================
# Setup: https://developers.facebook.com/
FACEBOOK_APP_ID=your_facebook_app_id  # REPLACE
FACEBOOK_APP_SECRET=your_facebook_app_secret  # REPLACE
FACEBOOK_PAGE_ID=your_facebook_page_id  # REPLACE
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token  # REPLACE
FACEBOOK_REDIRECT_URI=http://localhost:8080/facebook/callback
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_account_id  # REPLACE
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token  # REPLACE
META_GRAPH_API_VERSION=v19.0
META_ACCESS_TOKEN=your_meta_long_lived_token  # REPLACE

# =============================================================================
# PLATINUM TIER - CLOUD DEPLOYMENT
# =============================================================================
CLOUD_MODE=false
CLOUD_AGENT_ID=cloud-001
LOCAL_AGENT_ID=local-001
CLOUD_VM_IP=your.cloud.vm.ip.address  # REPLACE
CLOUD_VM_SSH_KEY=/path/to/ssh/key  # REPLACE
CLOUD_DOMAIN=your-domain.com  # REPLACE

# =============================================================================
# VAULT SYNC
# =============================================================================
VAULT_SYNC_METHOD=git
VAULT_GIT_REPO_URL=git@github.com:user/ai-employee-vault.git  # REPLACE
VAULT_GIT_BRANCH=main
VAULT_SYNC_INTERVAL=300
AGENT_NAME=local  # or 'cloud'

# =============================================================================
# WATCHER INTERVALS (seconds)
# =============================================================================
GMAIL_CHECK_INTERVAL=120
WHATSAPP_CHECK_INTERVAL=60
FILESYSTEM_CHECK_INTERVAL=30
SOCIAL_MEDIA_CHECK_INTERVAL=300

# =============================================================================
# RETRY CONFIGURATION
# =============================================================================
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2
RETRY_BACKOFF_MAX=60
RETRY_BACKOFF_JITTER=1.0

# =============================================================================
# RATE LIMITING
# =============================================================================
RATE_LIMIT_EMAIL_PER_HOUR=50
RATE_LIMIT_SOCIAL_PER_HOUR=100
RATE_LIMIT_ODOO_PER_MINUTE=60

# =============================================================================
# RALPH WIGGUM LOOP
# =============================================================================
RALPH_MAX_ITERATIONS=10
RALPH_TIMEOUT_SECONDS=3600
LLM_MODEL=claude
GEMINI_API_KEY=your_gemini_api_key  # REPLACE if using Gemini

# =============================================================================
# AUDIT LOGGING
# =============================================================================
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_DIR=./AI_Employee_Vault/Audit_Logs

# =============================================================================
# CEO BRIEFING
# =============================================================================
CEO_BRIEFING_DAY=Monday
CEO_BRIEFING_TIME=09:00
CEO_BRIEFING_EMAIL_RECIPIENT=

# =============================================================================
# SECURITY
# =============================================================================
SESSION_TIMEOUT_HOURS=24
TOKEN_REFRESH_BUFFER_MINUTES=15

# =============================================================================
# HEALTH CHECK & MONITORING
# =============================================================================
HEALTH_CHECK_PORT=8080
UPTIME_MONITOR_URL=http://localhost:8080/health

# =============================================================================
# WEBHOOK CONFIGURATION
# =============================================================================
WEBHOOK_PORT=5000
WEBHOOK_URL=http://localhost:5000/whatsapp

# =============================================================================
# MCP SERVER CONFIGURATION
# =============================================================================
EMAIL_MCP_ENABLED=true
SOCIAL_MCP_ENABLED=true
ODOO_MCP_ENABLED=true
LINKEDIN_MCP_ENABLED=true

# =============================================================================
# ORCHESTRATOR
# =============================================================================
# VAULT_PATH_OVERRIDE=/custom/path/to/vault
GMAIL_WATCHER_ENABLED=true
WHATSAPP_WATCHER_ENABLED=true
FILESYSTEM_WATCHER_ENABLED=true

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
