# AI Employee System - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# =============================================
# DEVELOPMENT MODE (Always true for safety)
# =============================================
DRY_RUN=true
LOG_LEVEL=INFO

# =============================================
# ODOO CONFIGURATION (Gold Tier)
# =============================================
# Odoo Community 19+ self-hosted instance
ODOO_URL=http://localhost:8069
ODOO_DB=odoo_db
ODOO_USERNAME=admin
ODOO_API_KEY=your_odoo_api_key_here

# =============================================
# GMAIL/OAUTH CONFIGURATION
# =============================================
# For Gmail API access (Email MCP and Gmail Watcher)
GMAIL_CREDENTIALS=/path/to/your/gmail/credentials.json
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:8080/callback

# =============================================
# LINKEDIN CONFIGURATION
# =============================================
# For LinkedIn posting
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:8080/linkedin/callback

# =============================================
# FACEBOOK/INSTAGRAM CONFIGURATION (Gold Tier)
# =============================================
# Facebook Developer App credentials
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_PAGE_ID=your_facebook_page_id
FACEBOOK_REDIRECT_URI=http://localhost:8080/facebook/callback

# Instagram Business Account (linked to Facebook Page)
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id

# =============================================
# TWITTER/X CONFIGURATION (Gold Tier)
# =============================================
# Twitter Developer App credentials
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# =============================================
# RETRY CONFIGURATION (Gold Tier)
# =============================================
# Error recovery and retry logic
MAX_RETRIES=3
RETRY_BACKOFF_BASE=2
RETRY_BACKOFF_MAX=60
RETRY_BACKOFF_JITTER=1.0

# =============================================
# RATE LIMITING (Gold Tier)
# =============================================
# Prevent API abuse
RATE_LIMIT_EMAIL_PER_HOUR=50
RATE_LIMIT_SOCIAL_PER_HOUR=100
RATE_LIMIT_ODOO_PER_MINUTE=60

# =============================================
# RALPH WIGGUM LOOP CONFIGURATION (Gold Tier)
# =============================================
# Autonomous task completion
RALPH_MAX_ITERATIONS=10
RALPH_TIMEOUT_SECONDS=3600

# =============================================
# AUDIT LOGGING CONFIGURATION (Gold Tier)
# =============================================
# Log retention and storage
AUDIT_LOG_RETENTION_DAYS=90
AUDIT_LOG_DIR=./AI_Employee_Vault/Audit_Logs

# =============================================
# CEO BRIEFING CONFIGURATION (Gold Tier)
# =============================================
# Weekly audit schedule
CEO_BRIEFING_DAY=Monday
CEO_BRIEFING_TIME=08:00
CEO_BRIEFING_EMAIL_RECIPIENT=

# =============================================
# WATCHER CONFIGURATION
# =============================================
# Check intervals in seconds
GMAIL_CHECK_INTERVAL=120
WHATSAPP_CHECK_INTERVAL=60
FILESYSTEM_CHECK_INTERVAL=30
SOCIAL_MEDIA_CHECK_INTERVAL=300

# =============================================
# SECURITY CONFIGURATION
# =============================================
# Session and token management
SESSION_TIMEOUT_HOURS=24
TOKEN_REFRESH_BUFFER_MINUTES=15
